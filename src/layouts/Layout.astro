---
// Base layout — wraps every page.
// Fetches the header and footer menus from Devigo and passes them to the
// Header and Footer components. Accepts a `title` prop for the <title> tag.

import { devigo } from '../lib/devigo.js';
import Header from '../components/menus/Header.astro';
import Footer from '../components/menus/Footer.astro';
import ConsentBanner from '../components/ConsentBanner.astro';

const { title, description, ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Fetch menus — these calls run at build time (static) or per-request (SSR).
const [headerMenu, footerMenu] = await Promise.all([
	devigo.menus.get('header').catch(() => ({ items: [] })),
	devigo.menus.get('footer').catch(() => ({ items: [] })),
]);

// Pass credentials to the client-side tracking script via data attributes.
// These are already public (sent in every API request from the browser).
const trackingConfig = {
	baseUrl: import.meta.env.DEVIGO_API_DOMAIN,
	siteId: import.meta.env.DEVIGO_SITE_ID,
	token: import.meta.env.DEVIGO_API_TOKEN,
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="canonical" href={canonicalURL} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

		<title>{title}</title>
		{description && <meta name="description" content={description} />}

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		{description && <meta property="og:description" content={description} />}
		{ogImage && <meta property="og:image" content={ogImage} />}

		<!-- Twitter -->
		<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
		<meta name="twitter:title" content={title} />
		{description && <meta name="twitter:description" content={description} />}
		{ogImage && <meta name="twitter:image" content={ogImage} />}

		<meta name="generator" content={Astro.generator} />
	</head>
	<body>
		<Header items={headerMenu.items} />
		<main>
			<slot />
		</main>
		<Footer items={footerMenu.items} />
		<ConsentBanner />

		<script
			is:inline
			data-base-url={trackingConfig.baseUrl}
			data-site-id={trackingConfig.siteId}
			data-token={trackingConfig.token}
		>
			(function () {
				var script = document.currentScript;
				var baseUrl = script.getAttribute('data-base-url').replace(/\/$/, '');
				var siteId = script.getAttribute('data-site-id');
				var token = script.getAttribute('data-token');
				var endpoint = baseUrl + '/api/display/' + siteId + '/track';

				function track() {
					if (localStorage.getItem('devigo_consent') !== 'true') return;

					var params = new URLSearchParams(window.location.search);
					var payload = {
						url: window.location.href,
						referrer: document.referrer || null,
						utm_source: params.get('utm_source') || null,
						utm_medium: params.get('utm_medium') || null,
						utm_campaign: params.get('utm_campaign') || null,
						user_agent: navigator.userAgent,
						screen_width: window.innerWidth,
					};

					fetch(endpoint, {
						method: 'POST',
						headers: {
							'Content-Type': 'application/json',
							'Authorization': 'Bearer ' + token,
						},
						body: JSON.stringify(payload),
						keepalive: true,
					}).catch(function () {});
				}

				// Expose for ConsentBanner to call on first accept
				window.__devigoTrack = track;

				// Track initial page load
				track();

				// Track client-side navigation (SPA)
				window.addEventListener('popstate', track);

				var originalPushState = history.pushState;
				history.pushState = function () {
					originalPushState.apply(history, arguments);
					track();
				};

				var originalReplaceState = history.replaceState;
				history.replaceState = function () {
					originalReplaceState.apply(history, arguments);
					track();
				};
			})();
		</script>
	</body>
</html>
