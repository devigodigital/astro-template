---
// ConsentBanner.astro
// Renders a consent banner for analytics tracking.
// If the user has already made a choice, the banner does not render.
// Completely unstyled — apply your own CSS as needed.
---

<div id="devigo-consent-banner">
    <p>This site uses analytics to understand how pages are used. No personal data is stored.</p>
    <div>
        <button id="devigo-consent-accept" type="button">Accept</button>
        <button id="devigo-consent-decline" type="button">Decline</button>
    </div>
</div>

<script>
    (function () {
        var banner = document.getElementById('devigo-consent-banner');
        if (!banner) return;

        var stored = localStorage.getItem('devigo_consent');
        if (stored !== null) {
            banner.remove();
            return;
        }

        document.getElementById('devigo-consent-accept')?.addEventListener('click', function () {
            localStorage.setItem('devigo_consent', 'true');
            banner.remove();
            // Trigger first track now that consent was just granted
            window.__devigoTrack?.();
        });

        document.getElementById('devigo-consent-decline')?.addEventListener('click', function () {
            localStorage.setItem('devigo_consent', 'false');
            banner.remove();
        });
    })();
</script>
