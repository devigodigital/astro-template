---
// Site header — renders the header navigation menu.
// Receives menu items from Layout.astro. Style the <header>, <nav>, and <ul> as needed.

import MenuItems from './MenuItems.astro';

const { items } = Astro.props;
---

<header style="padding: 16px 24px; border-bottom: 1px solid #777777;">
	<nav>
		<ul style="list-style: none; margin: 0; padding: 0; display: flex; gap: 24px;">
			<MenuItems items={items} />
		</ul>
	</nav>
</header>
