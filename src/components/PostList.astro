---
// Shared post listing with pagination links.
// Used by both [type]/index.astro and [type]/page/[page].astro.

const { type, entries, page, totalPages } = Astro.props;
---

{entries.length === 0 && <p>No entries found.</p>}
<ul>
	{entries.map((entry) => (
		<li>
			<a href={`/${type}/${entry.slug}`}>
				{entry.field_values?.title || entry.slug}
			</a>
		</li>
	))}
</ul>

{totalPages > 1 && (
	<nav aria-label="Pagination">
		{page > 1 && (
			<a href={page === 2 ? `/${type}` : `/${type}/page/${page - 1}`}>
				Previous
			</a>
		)}
		{Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
			<a
				href={p === 1 ? `/${type}` : `/${type}/page/${p}`}
				aria-current={p === page ? 'page' : undefined}
			>
				{p}
			</a>
		))}
		{page < totalPages && (
			<a href={`/${type}/page/${page + 1}`}>
				Next
			</a>
		)}
	</nav>
)}
