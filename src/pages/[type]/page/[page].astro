// const entries = collection.data;
// const totalPages = Math.ceil(collection.total / postsPerPage);
// ─────────────────────────────────────────────────────────────────────────────
---

<Layout title={`${type} — Page ${page}`}>
	<PostList type={type} entries={entries} page={page} totalPages={totalPages} />
</Layout>
